# gerege-template-ai-web — орчны хувьсагч
#
# Энэ frontend нь BFF (Backend-for-Frontend) загвартай: browser зөвхөн Next.js
# рүү хандана, Next.js server нь Go backend руу прокси хийнэ. Тиймээс доорх
# BACKEND_URL зөвхөн server талд (route handler-ууд, server component) уншигдана.

# gerege-template-ai-v1.0 ажиллаж буй хаяг (api/v1 угтваргүй суурь).
# Жишээ: http://localhost:8080  →  бодит дуудлага http://localhost:8080/api/v1/...
BACKEND_URL=http://localhost:8080

# Cookie-г Secure болгох эсэх. Production (HTTPS) дээр заавал true.
# Dev (http://localhost) дээр Secure cookie илгээгдэхгүй тул false.
COOKIE_SECURE=false

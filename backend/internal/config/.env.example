# APP
PORT=8080
ENVIRONMENT=development
DEBUG=true

# Comma-separated allowed CORS origins. Required in production. Leave empty in dev to fall back to "*".
ALLOWED_ORIGINS=

# Comma-separated reverse-proxy IPs/CIDRs that Fiber should trust to set the
# X-Forwarded-For header. REQUIRED in production behind nginx/ALB/Cloudflare —
# otherwise c.IP() returns the proxy IP for every request and rate limiting /
# audit logs see one global client. Leave empty in dev (no proxy in front).
# Examples: "127.0.0.1,::1" for sidecar; "172.18.0.0/16" for docker compose net.
TRUSTED_PROXIES=

# DATABASE

# POSTGRE
# dev: DSN (sslmode=disable is OK on localhost only)
# prod: DB_POSTGRE_URL MUST use sslmode=verify-full (CA + hostname checked)
#       — enforced by config validation (secure_system_guide §3.5).
DB_POSTGRE_DRIVER=postgres
DB_POSTGRE_DSN=user=myuser password=mypassword host=myhost port=5432 dbname=mydb sslmode=disable timezone=Asia/Jakarta
DB_POSTGRE_URL=postgres://user:pass@host/db?sslmode=verify-full

# DB pool (optional; defaults 25/5/15)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFE_MINS=15

# JWT — secret MUST be at least 32 characters
JWT_SECRET=change-me-to-a-long-random-string-of-32-or-more-chars
JWT_EXPIRED=5                # access token TTL in hours
JWT_REFRESH_EXPIRED=7        # refresh token TTL in days
JWT_ISSUER=snykk_here

# OTP
OTP_EMAIL=patrick@gmail.com
OTP_PASSWORD=idonthavepassword
OTP_MAX_ATTEMPTS=5

# Mailer workers (optional; defaults 2/64/3). Mail IO happens off the request path.
MAILER_WORKERS=2
MAILER_QUEUE_SIZE=64
MAILER_RETRIES=3

# bcrypt cost (10–31; default 12 ≈ 100–200ms on 2026 hardware).
BCRYPT_COST=12

# OpenTelemetry tracing — leave OTEL_EXPORTER empty to disable (noop tracer).
# Set "stdout" in dev to print spans, or "otlp" in production with the
# standard OTEL_EXPORTER_OTLP_ENDPOINT env pointing at a collector.
OTEL_EXPORTER=
OTEL_SAMPLE_RATIO=1.0

# CACHE

# REDIS
REDIS_HOST=localhost:6969
REDIS_PASS=mydangdingdong
REDIS_EXPIRED=5

# GeregeCloud Verify (verify.gecloud.mn) — OTP send/check. SendOTP / VerifyOTP
# усецase-ууд кодыг үүсгэх / SMTP-ээр илгээх ажлаа энд шилжүүлдэг. VERIFY_API_KEY
# хоосон бол клиент бүтэх боловч дуудлага бүр "missing api key" алдаа буцаах
# тул operator-д чимээгүй буруу тохиргоо үлдэхгүй. Channel: "email" эсвэл "sms".
VERIFY_API_BASE=https://api.gecloud.mn/v1/verify
VERIFY_API_KEY=
VERIFY_CHANNEL=email
# AI assistant (Anthropic Claude). Leave ANTHROPIC_API_KEY empty to disable —
# /api/v1/ai/* endpoints then return 503 "ai service is not configured".
# The key stays server-side only; it is never sent to the frontend/browser.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=1024
AI_DAILY_REQUEST_LIMIT=50
AI_REQUEST_TIMEOUT_SECS=120
# Max history messages sent to Claude as context. Higher = better quality but
# more token cost. Empty/<=0 falls back to the default of 20.
AI_HISTORY_LIMIT=20
# Gemini voice translation (STT -> MN<->EN -> TTS). Empty key makes the
# /api/v1/voice/* endpoints return 503. Key stays backend-only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_VOICE=Kore
VOICE_DAILY_REQUEST_LIMIT=50
VOICE_REQUEST_TIMEOUT_SECS=25
# Max raw audio per request (KiB); base64 + JSON must fit the global 1 MiB cap.
VOICE_MAX_AUDIO_KB=640

# Backend config mounted into the api + migrate containers at /app/.env.
# Copy to `backend.env` (gitignored) and fill in real secrets for deployment.
# DB host/redis host use the compose service names (db, redis).

PORT=8080
ENVIRONMENT=development        # internal docker DB has no TLS; dev mode skips the verify-full guard
DEBUG=false
ALLOWED_ORIGINS=https://temp.gerege.mn

# Reverse-proxy IPs/CIDRs Fiber trusts for X-Forwarded-For. Required behind a
# proxy — without it c.IP() returns the proxy IP for every request and rate
# limiting / audit logs collapse to one client. Compose's default bridge net
# uses 172.17/16; user-defined networks pick another /16 — adjust as needed.
TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12

# NOTE: the users table enforces Postgres Row-Level Security (migration 6).
# RLS is bypassed by SUPERUSER / BYPASSRLS roles, and the postgres image makes
# POSTGRES_USER a superuser — so for RLS to take effect, point this DSN at a
# NON-superuser role (see backend/docs/SECURITY.md "DB role separation").
DB_POSTGRE_DRIVER=postgres
DB_POSTGRE_DSN=host=db port=5432 user=gerege password=CHANGE_ME_DB dbname=gerege_template sslmode=disable
DB_POSTGRE_URL=postgres://db:5432/gerege_template?sslmode=verify-full
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFE_MINS=15

JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_PLUS_CHAR_SECRET
JWT_EXPIRED=5
JWT_REFRESH_EXPIRED=7
JWT_ISSUER=temp.gerege.mn

OTP_EMAIL=noreply@temp.gerege.mn
OTP_PASSWORD=CHANGE_ME_SMTP_OR_DUMMY
OTP_MAX_ATTEMPTS=5

BCRYPT_COST=12

OTEL_EXPORTER=
OTEL_SAMPLE_RATIO=1.0

REDIS_HOST=redis:6379
REDIS_PASS=CHANGE_ME_REDIS
REDIS_EXPIRED=5

# GeregeCloud Verify (verify.gecloud.mn) — OTP send/check. API нь кодыг өөрөө
# үүсгэж, хадгалж, шалгадаг. VERIFY_API_KEY хоосон бол SendOTP/VerifyOTP
# усецase-ууд тэр даруй "missing api key"-ээр амжилтгүй болно. Channel-ийг
# email эсвэл sms-ээр сонгоно (бүртгэлийн төрөл хоосон бол default = email).
VERIFY_API_BASE=https://api.gecloud.mn/v1/verify
VERIFY_API_KEY=CHANGE_ME_GECLOUD_VERIFY_KEY
VERIFY_CHANNEL=email

# AI туслах (Anthropic Claude). ANTHROPIC_API_KEY хоосон бол /api/v1/ai/*
# endpoint-ууд 503 "ai service is not configured" буцаана. Түлхүүр зөвхөн
# backend талд хадгалагдана — frontend/browser руу хэзээ ч дамжихгүй.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Нэг хариунд зөвшөөрөх output токены дээд тоо (кост хяналт).
AI_MAX_TOKENS=1024
# Нэг хэрэглэгчийн өдрийн AI чат хүсэлтийн хязгаар (Redis тоолуур, UTC өдрөөр).
AI_DAILY_REQUEST_LIMIT=50
# Нэг streaming хариуны дээд хугацаа (секунд) — глобал 30с timeout streaming-д
# үйлчилдэггүй тул тусдаа.
AI_REQUEST_TIMEOUT_SECS=120
# Claude руу контекст болгон дамжуулах түүхийн мессежийн дээд тоо. Том утга
# чанарыг сайжруулж болох ч токены зардлыг өсгөнө. Хоосон бол default 20.
AI_HISTORY_LIMIT=20
# Gemini (дуу хоолойн орчуулга: STT → MN↔EN → TTS). GEMINI_API_KEY хоосон
# бол /api/v1/voice/* endpoint-ууд 503 "voice service is not configured"
# буцаана. Түлхүүр зөвхөн backend талд хадгалагдана.
GEMINI_API_KEY=
# Аудио ойлгож орчуулах multimodal модель.
GEMINI_MODEL=gemini-2.5-flash
# Орчуулгыг яриа болгох (text-to-speech) модель.
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# TTS-ийн prebuilt дуу хоолойн нэр (Kore, Puck, Zephyr, Charon г.м.).
GEMINI_VOICE=Kore
# Нэг хэрэглэгчийн өдрийн дуу хоолойн орчуулгын хязгаар (Redis тоолуур).
VOICE_DAILY_REQUEST_LIMIT=50
# Нэг Gemini дуудлагын дээд хугацаа (секунд). Pipeline 2 дуудлага хийдэг
# тул нийлбэр глобал 30с timeout дотор багтахаар сонгоно.
VOICE_REQUEST_TIMEOUT_SECS=25
# Нэг хүсэлтэд зөвшөөрөх түүхий аудионы дээд хэмжээ (KiB). Base64-тэй
# нийлэхэд глобал 1 MiB body cap дотор багтах ёстой (640 KiB ≈ base64 853 KiB).
VOICE_MAX_AUDIO_KB=640

# Production-д /metrics ба /swagger/doc.json endpoint-уудыг хамгаалах
# Bearer token. Хоосон бол production-д тэдгээр endpoint 404 буцаана.
# Dev-д энэ утга үл хамаарна (endpoint үргэлж ил). Жишээ үүсгэх:
#   openssl rand -base64 32
OBSERVABILITY_TOKEN=
